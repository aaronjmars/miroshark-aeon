# macOS
.DS_Store

# Secrets & local env
.env
.env.local
.env.*.local

# Claude Code local state
.claude/

# Caches — prefetch scripts write these, skills read them; regenerated every run
# (.xai-cache, .treasury-cache, .star-cache, .github-releases-cache, …)
.*-cache/
.tg_cache/

# Working scratch dirs some skills stage during a run, then clean up:
# .pending-notify (notify re-delivery), .pending-deploy (deploy-prototype build),
# plus .pending-notify-temp where skills stage notify bodies for `./notify -f`
.pending-*/

# Skill provenance lock (per-repo, not committed)
skills.lock

# Scratch / temp files
tmp_*
*.tmp
.tmp-*
.pending-*.sh
.run-*.sh
.*-tmp.md
.*-draft.md
.*-msg.txt
*_msg.txt
*_raw.txt

# Leaked creds scratch
.xai_key
.ghtoken

# Python bytecode
__pycache__/
*.pyc

# Node
node_modules/

# Stale artifacts
.external-work
.vuln-scan/

# Runtime artifacts the runner drops in-tree each run — the auto-commit does
# `git add -A`, which sweeps them into a chore commit unless they're ignored.
# `secretcurl` is the auth shim regenerated from scripts/secretcurl.sh every run.
/secretcurl

# Notify bodies — skills stage a digest for `./notify -f` (→ /tmp or
# .pending-notify/); any copy left in-tree is transient junk, never durable state.
# Un-anchored so it also catches the dated (notify-token-report-YYYY-MM-DD.md),
# output/ (changelog-notify.md), and dotfile (.repo-pulse-notify.md) forms — and
# inside a validated OKF root (memory/) a notify body would break ci-okf, since
# §9 needs a `type:` frontmatter it never carries. A notify body is not a concept.
*-notify.md
.*-notify.md
notify-*.md

# xai API request/response scratch — the shiplog/fetch-tweets skills write these
# to /tmp; committed copies (root or memory/) are pure `git add -A` leaks, never
# read from in-tree. (cf. the token-movers xai-payload.json that leaked to root.)
xai-*.json
