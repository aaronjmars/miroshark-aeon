/.aeon-tmp-*
/sig_smoke.py
/_smoke_*.py
/*_smoke.py
/verify-*.py

# Leaked creds scratch
.xai_key
.ghtoken

# Python bytecode
__pycache__/
*.pyc

# Node
node_modules/

# Stale artifacts
.external-work
.vuln-scan/
