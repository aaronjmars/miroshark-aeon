# macOS
.DS_Store

# Secrets & local env
.env
.env.local
.env.*.local

# Claude Code local state
.claude/

# Caches — prefetch scripts write these, skills read them; regenerated every run
# (.xai-cache, .treasury-cache, .star-cache, .github-releases-cache, …)
.*-cache/
.tg_cache/

# Working scratch dirs some skills stage during a run, then clean up:
# .pending-notify (notify re-delivery), .pending-deploy (deploy-prototype build),
# plus .pending-notify-temp where skills stage notify bodies for `./notify -f`
.pending-*/

# Skill provenance lock (per-repo, not committed)
skills.lock

# Scratch / temp files
tmp_*
*.tmp
.tmp-*
.pending-*.sh
.run-*.sh
.*-tmp.md
.*-draft.md
.*-msg.txt
*_msg.txt
*_raw.txt

# Leaked creds scratch
.xai_key
.ghtoken

# Python bytecode
__pycache__/
*.pyc

# Node
node_modules/

# Stale artifacts
.external-work
.vuln-scan/

# Runtime artifacts the runner drops at the repo root each run — the auto-commit
# does `git add -A`, which sweeps them into a chore commit if they aren't ignored.
# `secretcurl` is the auth shim regenerated from scripts/secretcurl.sh every run;
# `notify-token-report.md` is a stray token-movers digest (skill now writes /tmp).
/secretcurl
/notify-token-report.md

# Stray notify-body payloads that leak INTO a validated OKF root (memory/) via
# `git add -A`. Skills stage a digest body for `./notify -f`, then the auto-commit
# sweeps it in; inside memory/ it fails ci-okf (§9 needs a `type:` frontmatter).
# These are transient — a notify body is never a memory concept. (cf. the stray
# tweet-digest-notify.md that broke ci-okf; the tweet-digest skill merged into
# fetch-tweets, which now delivers via ./notify → .pending-notify/.)
memory/*-notify.md
memory/notify-*.md
