      "type": "Text",
      "props": {
        "text": "German (de) locale complete end-to-end",
        "variant": "lead"
      }
    },
    "german_details": {
      "type": "Text",
      "props": {
        "text": "dan-and filled 8 empty prompt modules in backend/app/prompts/locales/de/ and fixed locale propagation across parallel profile/config threads; DE sims no longer fall back to English",
        "variant": "body"
      }
    },
    "german_pr": {
      "type": "StoryLink",
      "props": {
        "title": "#189",
        "href": "https://github.com/aaronjmars/miroshark/pull/189"
      }
    },
