      "children": [
        "scenarios_title",
        "scenarios_details",
        "scenarios_pr"
      ]
    },
    "scenarios_title": {
      "type": "Text",
      "props": {
        "text": "suggest_scenarios can no longer return zero results from truncation",
        "variant": "lead"
      }
    },
    "scenarios_details": {
      "type": "Text",
      "props": {
        "text": "new json_repair.py does two-tier best-effort recovery (close brackets → parse; trim to last complete element → retry), consolidating 3 copy-pasted salvage blocks; valid suggestions are never silently dropped",
        "variant": "body"
      }
    },
    "scenarios_pr": {
      "type": "StoryLink",
      "props": {
        "title": "#192",
        "href": "https://github.com/aaronjmars/miroshark/pull/192"
