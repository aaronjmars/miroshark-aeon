        "cost_details",
        "cost_pr"
      ]
    },
    "cost_title": {
      "type": "Text",
      "props": {
        "text": "Public embed widget now shows the sim cost as ~$X",
        "variant": "lead"
      }
    },
    "cost_details": {
      "type": "Text",
      "props": {
        "text": "cost.json pill lands in the meta row where strangers first encounter a MiroShark result; 403/404 swallowed so it never blocks",
        "variant": "body"
      }
    },
    "cost_pr": {
      "type": "StoryLink",
