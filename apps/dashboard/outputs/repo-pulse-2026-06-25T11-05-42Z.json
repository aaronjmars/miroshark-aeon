{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse",
        "description": "2026-06-25"
      },
      "children": [
        "header",
        "separator1",
        "repo_section",
        "separator2",
        "stargazers_section",
        "separator3",
        "source"
      ]
    },
    "header": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "status_badge"
      ]
    },
    "status_badge": {
      "type": "Badge",
      "props": {
        "text": "STEADY",
        "variant": "default"
      }
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "repo_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "repo_name",
        "repo_stats"
      ]
    },
    "repo_name": {
      "type": "Link",
      "props": {
        "label": "aaronjmars/MiroShark",
        "href": "https://github.com/aaronjmars/MiroShark"
      }
    },
    "repo_stats": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stars_stat",
        "forks_stat"
      ]
    },
    "stars_stat": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1333",
        "delta": "+1",
        "trend": "up"
      }
    },
    "forks_stat": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "278"
      }
    },
    "separator2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stargazers_heading",
        "stargazer_item"
      ]
    },
    "stargazers_heading": {
      "type": "Heading",
      "props": {
        "text": "Notable new stargazers",
        "level": "h3"
      }
    },
    "stargazer_item": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "stargazer_link",
        "stargazer_count"
      ]
    },
    "stargazer_link": {
      "type": "Link",
      "props": {
        "label": "github.com/mesubbu",
        "href": "https://github.com/mesubbu"
      }
    },
    "stargazer_count": {
      "type": "Text",
      "props": {
        "text": "20 repos",
        "variant": "body"
      }
    },
    "separator3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "source": {
      "type": "Text",
      "props": {
        "text": "Source: events",
        "variant": "caption"
      }
    }
  }
}
