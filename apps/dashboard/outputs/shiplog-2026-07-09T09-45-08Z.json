    "stat-aeon-stars": {
      "type": "Stat",
      "props": {
        "label": "aeon GitHub Stars",
        "value": "571",
        "delta": "+3",
        "trend": "up"
      }
    },
    "stat-miroshark-stars": {
      "type": "Stat",
      "props": {
        "label": "MiroShark GitHub Stars",
        "value": "1,357",
        "delta": "+0",
        "trend": "neutral"
      }
