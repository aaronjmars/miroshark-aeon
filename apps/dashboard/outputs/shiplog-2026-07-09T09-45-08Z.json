{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Shiplog: aeon ⭐ + miroshark 🦈 (Jul 6 → Jul 9)"
      },
      "children": [
        "overview-text",
        "features-heading",
        "features-stack",
        "separator-1",
        "traction-heading",
        "stats-grid",
        "rankings-stack",
        "separator-2",
        "link-repo"
      ]
    },
    "overview-text": {
      "type": "Text",
      "props": {
        "text": "Shipped ~95 PRs this window. The bytes:",
        "variant": "lead"
      }
    },
    "features-heading": {
      "type": "Heading",
      "props": {
        "text": "Features & Improvements",
        "level": "h3"
      }
    },
    "features-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "feature-attestation",
        "feature-secrets",
        "feature-website",
        "feature-farcaster",
        "feature-cli",
        "feature-langfuse",
        "feature-sparkleware",
        "feature-security"
      ]
    },
    "feature-attestation": {
      "type": "Text",
      "props": {
        "text": "Attestation: Every aeon skill run now signs a cryptographic proof via Sigstore. Verify the run happened. Gate on-chain actions behind proof-of-execution. @aeonframework ⭐"
      }
    },
    "feature-secrets": {
      "type": "Text",
      "props": {
        "text": "Secrets Overhaul: Retired the prefetch model entirely — 7 PRs. Skills now call XAI/CoinGecko/Alchemy in-run via per-skill secretcurl. Cleaner, faster, no pre-caching scaffolding."
      }
    },
    "feature-website": {
      "type": "Text",
      "props": {
        "text": "MiroShark Website Rebuild: 0x swap widget (buy $MIROSHARK directly), credit card onramp, X/GitHub/Google/wallet login, PostHog analytics, 3D token emblem — 22 PRs in 3 days. Also: first $MIROSHARK buyback from 100% of x402 endpoint revenue 🦈"
      }
    },
    "feature-farcaster": {
      "type": "Text",
      "props": {
        "text": "Farcaster Mini App: MiroShark now live on @farcaster_xyz — simulate anything, dozens of agents, a few minutes."
      }
    },
    "feature-cli": {
      "type": "Text",
      "props": {
        "text": "Aeon CLI: Headless `aeon` binary, full read+write, reuses dashboard lib. Cron is trivial ⭐"
      }
    },
    "feature-langfuse": {
      "type": "Text",
      "props": {
        "text": "Langfuse: Optional full tracing for aeon runs — session-level observability, not just logs."
      }
    },
    "feature-sparkleware": {
      "type": "Text",
      "props": {
        "text": "Sparkleware: Holographic registry for @aeonframework skill packs, live + tradeable on @virtuals_io and Robinhood. Ecosystem building itself."
      }
    },
    "feature-security": {
      "type": "Text",
      "props": {
        "text": "Security: ws (CVE-2026-48779) + postcss (CVE-2026-41305) + chain-input injection (GHSA-h9v2/GHSA-cqvj) patched across 6 repos."
      }
    },
    "separator-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "traction-heading": {
      "type": "Heading",
      "props": {
        "text": "Traction",
        "level": "h3"
      }
    },
    "stats-grid": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": "md"
      },
      "children": [
        "stat-aeon-stars",
        "stat-miroshark-stars"
