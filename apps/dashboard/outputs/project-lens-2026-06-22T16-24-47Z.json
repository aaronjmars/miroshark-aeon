    "heading_problem": {
      "type": "Heading",
      "props": {
        "text": "The Representative Agent Problem",
        "level": "h2"
      },
      "children": []
    },
    "text_theorem": {
      "type": "Text",
      "props": {
        "text": "The Sonnenschein-Mantel-Debreu theorem (1970s) proved you can't recover a population's distributional structure from its aggregate — what economists call the representative agent."
      },
      "children": []
    },
    "text_ostrom": {
      "type": "Text",
      "props": {
        "text": "Elinor Ostrom's Nobel work showed the same thing in practice: Maine's lobster fishery runs on six officers for 6,800 fishermen precisely because governance adapted to heterogeneous actors rather than averaging over them."
      },
      "children": []
    },
    "text_aggregate": {
      "type": "Text",
      "props": {
        "text": "The same architectural fork now exists in simulation: synthetic user tools interview N isolated personas and aggregate, producing a representative agent."
      },
      "children": []
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
    },
