{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "heartbeat"
      },
      "children": [
        "stack-content"
      ]
    },
    "stack-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "alert-deadline",
        "separator-1",
        "memory-details",
        "memory-note"
      ]
    },
    "alert-deadline": {
      "type": "Alert",
      "props": {
        "title": "CN-locale Hyperstition Deadline",
        "message": "Deadline tomorrow (2026-06-15)",
        "type": "warning"
      }
    },
    "separator-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "memory-details": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "text-coverage",
        "badges-stack"
      ]
    },
    "text-coverage": {
      "type": "Text",
      "props": {
        "text": "CN tweet from May 16 (\"米罗莎要来了\") likely qualifies as coverage"
      }
    },
    "badges-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "badge-cn",
        "badge-coverage",
        "badge-archive"
      ]
    },
    "badge-cn": {
      "type": "Badge",
      "props": {
        "text": "CN-locale",
        "variant": "secondary"
      }
    },
    "badge-coverage": {
      "type": "Badge",
      "props": {
        "text": "coverage",
        "variant": "secondary"
      }
    },
    "badge-archive": {
      "type": "Badge",
      "props": {
        "text": "flagged for archive/CROSSED",
        "variant": "outline"
      }
    },
    "memory-note": {
      "type": "Text",
      "props": {
        "text": "MEMORY.md flags this item for archive/CROSSED today",
        "variant": "muted"
      }
    }
  }
}
