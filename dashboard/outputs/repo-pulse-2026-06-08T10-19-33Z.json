{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "repo-name",
        "stats-section",
        "separator-1",
        "stargazers-section"
      ]
    },
    "repo-name": {
      "type": "Heading",
      "props": {
        "text": "aaronjmars/MiroShark",
        "level": "h2"
      }
    },
    "stats-section": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stat-stars",
        "stat-forks"
      ]
    },
    "stat-stars": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1241",
        "delta": "+2",
        "trend": "up"
      }
    },
    "stat-forks": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "263",
        "delta": "+0",
        "trend": "neutral"
      }
    },
    "separator-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stargazers-heading",
        "stargazers-list"
      ]
    },
    "stargazers-heading": {
      "type": "Heading",
      "props": {
        "text": "New stargazers",
        "level": "h3"
      }
    },
    "stargazers-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "link-farulwananda",
        "link-wanikua"
      ]
    },
    "link-farulwananda": {
      "type": "Link",
      "props": {
        "label": "github.com/farulwananda",
        "href": "https://github.com/farulwananda"
      }
    },
    "link-wanikua": {
      "type": "Link",
      "props": {
        "label": "github.com/wanikua",
        "href": "https://github.com/wanikua"
      }
    }
  }
}
