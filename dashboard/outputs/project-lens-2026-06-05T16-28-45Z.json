        "stat_outages",
        "stat_lag"
      ]
    },
    "text_report_title": {
      "type": "Text",
      "props": {
        "text": "IsDown's April 2026 report:",
        "variant": "lead"
      }
    },
    "stat_outages": {
      "type": "Stat",
      "props": {
        "label": "Unreported outages",
        "value": "104"
      }
    },
    "stat_lag": {
      "type": "Stat",
      "props": {
        "label": "Average status page lag",
        "value": "22 minutes"
      }
    },
    "text_connection": {
      "type": "Text",
      "props": {
        "text": "Read against that, PR #149 (merged into MiroShark at 13:01 UTC today) ships GET /api/status.json as the first /api/* endpoint with auth deliberately stripped — a literal ok: true anchor for body-matchers, total_sims tightened to public+completed so anonymous callers learn nothing private, and surface_count read from the same catalog_count() function /api/surfaces.json publishes.",
        "variant": "body"
      }
    },
    "text_pr": {
      "type": "Text",
      "props": {
        "text": "The third review-commit on the PR is the substance: every other /api/* endpoint inherits internal_auth_guard, this one had to actively drop it to deliver the contract the OpenAPI spec already documented.",
        "variant": "body"
      }
    },
    "separator_1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "link_article": {
      "type": "StoryLink",
      "props": {
        "title": "Read the full article",
        "href": "https://github.com/aaronjmars/miroshark-aeon/blob/main/articles/project-lens-2026-06-05.md",
        "source": "GitHub"
      }
    }
  }
