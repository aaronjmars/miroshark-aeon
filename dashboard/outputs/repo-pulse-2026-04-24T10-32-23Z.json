{
  "root": "card-repo-pulse",
  "state": {},
  "elements": {
    "card-repo-pulse": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "main-stack"
      ]
    },
    "main-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "repo-link",
        "stats-stack",
        "sep1",
        "stargazers-section",
        "sep2",
        "forks-section"
      ]
    },
    "repo-link": {
      "type": "StoryLink",
      "props": {
        "title": "aaronjmars/MiroShark",
        "href": "https://github.com/aaronjmars/MiroShark",
        "source": "GitHub"
      }
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "stat-stars",
        "stat-forks"
      ]
    },
    "stat-stars": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "798",
        "delta": "+10",
        "trend": "up"
      }
    },
    "stat-forks": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "149",
        "delta": "+2",
        "trend": "up"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-section": {
