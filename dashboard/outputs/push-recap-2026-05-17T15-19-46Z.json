        "transport_header",
        "transport_text",
        "transport_table"
      ]
    },
    "transport_header": {
      "type": "Heading",
      "props": {
        "text": "SMTP Transport Selection",
        "level": "h3"
      }
    },
    "transport_text": {
      "type": "Text",
      "props": {
        "text": "Transport selects by port; per-process (sim_id, status) dedup; fire-and-forget daemon-thread dispatch. The channel-notifier idiom now spans 5 transports: HTTP webhook, Discord HTTP, Slack HTTP, on-chain DKG daemon, SMTP.",
        "variant": "body"
      }
    },
    "transport_table": {
      "type": "Table",
      "props": {
        "columns": [
          "Port",
          "Transport",
          "Auth Required?"
        ],
        "rows": [
          [
            "465",
            "SMTP_SSL",
            "Yes"
          ],
          [
            "587",
            "SMTP+STARTTLS",
            "Yes"
          ],
          [
            "25",
            "Plain (unauthenticated LAN relay)",
            "No"
          ]
        ]
      }
    },
