        "sep7",
        "overall_stats",
        "sep8",
        "full_recap_link"
      ]
    },
    "repo_stats": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stat_pr",
        "stat_merge",
        "stat_commits"
      ]
    },
    "stat_pr": {
      "type": "Stat",
      "props": {
        "label": "Substantive PRs Opened",
        "value": "1"
      }
    },
    "stat_merge": {
      "type": "Stat",
      "props": {
        "label": "Merges to MiroShark Main",
        "value": "0"
      }
    },
    "stat_commits": {
      "type": "Stat",
      "props": {
        "label": "Housekeeping Commits (aeon main)",
        "value": "36"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "pr_header": {
      "type": "Heading",
      "props": {
        "text": "PR #87 — SMTP Email Notification Channel",
        "level": "h2"
      }
    },
    "pr_summary": {
      "type": "Text",
      "props": {
        "text": "PR #87 (open) lands SMTP email as the 4th completion-notification channel alongside webhook / Discord / Slack. Pure stdlib (smtplib + email.mime), zero new deps — preserves the 24-PR no-dependency streak from PR #57 (23 merged + 1 open).",
        "variant": "body"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "notification_design": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "design_header",
        "design_text1",
        "design_text2",
        "design_text3"
      ]
    },
    "design_header": {
      "type": "Heading",
      "props": {
        "text": "Design & Features",
        "level": "h3"
      }
    },
    "design_text1": {
      "type": "Text",
      "props": {
        "text": "Mirrors the discord_notify / slack_notify shape exactly; runner-side dispatch sites now five-deep at each terminal-state branch.",
        "variant": "body"
      }
    },
    "design_text2": {
      "type": "Text",
      "props": {
        "text": "Auth-optional, zero-platform-dependency design: blank SMTP_USER/SMTP_PASSWORD routes through an unauthenticated LAN relay (localhost:25 / self-hosted Postfix). Every research team already has an inbox — no Discord server or Slack workspace required for completion alerts.",
        "variant": "body"
      }
    },
    "design_text3": {
      "type": "Text",
      "props": {
        "text": "Visual language stays identical: same Unicode block bars Slack uses, same consensus colours Discord uses (#22c55e/#6b7280/#ef4444/#f59e0b), plus subject [MiroShark] <Direction>: <Scenario> for inbox triage.",
        "variant": "body"
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "security_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "security_header",
        "security_alert"
      ]
    },
    "security_header": {
      "type": "Heading",
      "props": {
        "text": "Security Posture",
        "level": "h3"
      }
    },
    "security_alert": {
      "type": "Alert",
      "props": {
        "title": "Credential-Leak Refusal",
        "message": "STARTTLS failure on a credentialed connection refuses to send rather than fall back to cleartext — same 'secret never crosses a degraded boundary' rule as HMAC signing in PR #79.",
        "type": "info"
      }
    },
    "sep4": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "transport_details": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
