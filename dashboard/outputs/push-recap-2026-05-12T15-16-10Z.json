      "props": {
        "text": "WEBHOOK_SECRET env → X-MiroShark-Signature: sha256=<hex> on every dispatch (Stripe/GitHub scheme). First MiroShark surface whose verification check runs on the recipient's hardware.",
        "variant": "body"
      },
      "children": []
    },
    "pr79_text2": {
      "type": "Text",
      "props": {
        "text": "Structural twin of PR #75 reproduce.json — both SHA-256 over deterministic bytes, both verifiable without trusting the server.",
        "variant": "body"
      },
      "children": []
    },
    "pr79_text3": {
      "type": "Text",
      "props": {
        "text": "Backward-compat: blank secret omits header entirely. Signature header never persisted to webhook-log.jsonl; receiver-side verify_signature published symmetrically.",
