    "pr80_text1": {
      "type": "Text",
      "props": {
        "text": "GET /api/simulation/<id>/notebook.ipynb returns a pre-populated nbformat 4 .ipynb with the trajectory CSV embedded inline + a 7-cell pinned analysis sequence (header → imports → load → belief chart → consensus → quality summary → footer). Runs air-gapped (no callback to host), bytewise-stable (sort_keys + indent=2 → SHA-256 = stable citation key). Pure stdlib, 559 LoC service + 20 offline tests.",
        "variant": "body"
      },
      "children": []
    },
    "pr80_text2": {
      "type": "Text",
      "props": {
        "text": "The 2nd export aimed at academic/institutional users after trajectory.csv: CSV said \"here is the data\", notebook says \"here is the analysis, ready to run\".",
