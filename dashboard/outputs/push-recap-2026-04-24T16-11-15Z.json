    },
    "change3": {
      "type": "Text",
      "props": {
        "text": "skills/fetch-tweets/SKILL.md — SEEN_IDS set extracted via regex from persistent seen-file + last 3 days of logs; reconciles with filter-xai-tweets.py's existing in-run ID dedup",
