    "heading_main": {
      "type": "Heading",
      "props": {
        "text": "Feature-Skill Scratch-File Leak Fix",
        "level": "h2"
      }
    },
    "intro_text": {
      "type": "Text",
      "props": {
        "text": "Deleted three throwaway Python verifier scripts (sig_smoke.py, _smoke_webhook.py, .aeon-tmp-verify-trending.py) that had been sitting at the repo root, and patched the feature skill so it stops dropping them there in the first place.",
        "variant": "lead"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {}
    },
    "why_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "why_heading",
        "why_text"
      ]
    },
    "why_heading": {
      "type": "Heading",
      "props": {
        "text": "Why",
        "level": "h3"
      }
    },
    "why_text": {
      "type": "Text",
      "props": {
        "text": "Yesterday's push-recap flagged it as second-day-in-a-row tech debt — the feature skill writes throwaway HMAC/sort verifiers, runs them, then the chain-runner's git add -A sweeps them onto main. Two consecutive feature runs (PR #78 trending sort, PR #79 webhook HMAC) leaked verifiers — that's a pattern, not a slip.",
        "variant": "body"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {}
    },
    "changes_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "lg"
      },
      "children": [
