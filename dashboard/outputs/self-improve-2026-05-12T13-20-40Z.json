        "change3_detail2"
      ]
    },
    "change3_title": {
      "type": "Heading",
      "props": {
        "text": "Deleted Files",
        "level": "h4"
      }
    },
    "change3_detail1": {
      "type": "Text",
      "props": {
        "text": "Removed three leaked files: sig_smoke.py, _smoke_webhook.py, .aeon-tmp-verify-trending.py (~3.7 KB total)",
        "variant": "body"
      }
    },
    "change3_detail2": {
      "type": "Text",
      "props": {
        "text": "All dead code — they import from /tmp/build-target/backend which only exists during a feature run",
        "variant": "body"
      }
    },
