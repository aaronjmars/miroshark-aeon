        "change1",
        "change2",
        "change3"
      ]
    },
    "changes_heading": {
      "type": "Heading",
      "props": {
        "text": "What Changed",
        "level": "h3"
      }
    },
    "change1": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "change1_title",
        "change1_detail1",
        "change1_detail2",
        "change1_detail3",
        "change1_detail4",
        "change1_detail5"
      ]
    },
    "change1_title": {
      "type": "Heading",
      "props": {
        "text": "skills/feature/SKILL.md",
        "level": "h4"
      }
    },
    "change1_detail1": {
      "type": "Text",
      "props": {
        "text": "Step 6 gains an explicit \"repo root is OFF-LIMITS\" block",
        "variant": "body"
      }
    },
    "change1_detail2": {
      "type": "Text",
      "props": {
        "text": "Verifier scripts must live in /tmp/verify-${feature}.py, never at the agent repo cwd",
        "variant": "body"
      }
    },
    "change1_detail3": {
      "type": "Text",
      "props": {
        "text": "Lists the past leak names",
        "variant": "body"
      }
    },
    "change1_detail4": {
      "type": "Text",
      "props": {
        "text": "Requires a pre-finish ls cleanup check",
        "variant": "body"
      }
    },
    "change1_detail5": {
      "type": "Text",
      "props": {
        "text": "Reminds that file-edit tools should target /tmp/build-target/, not relative paths",
        "variant": "body"
      }
    },
    "change2": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "change2_title",
        "change2_detail1",
        "change2_detail2"
      ]
    },
    "change2_title": {
      "type": "Heading",
      "props": {
        "text": ".gitignore",
        "level": "h4"
      }
    },
    "change2_detail1": {
      "type": "Text",
      "props": {
        "text": "Root-only safety net with patterns: /.aeon-tmp-*, /sig_smoke.py, /_smoke_*.py, /*_smoke.py, /verify-*.py — so even if a future skill drops one, git add -A won't pick it up",
        "variant": "body"
      }
    },
    "change2_detail2": {
      "type": "Text",
      "props": {
        "text": "Anchored to root so it can't hide a legitimate deep-path *_smoke.py test in dashboard/ or scripts/",
        "variant": "body"
      }
    },
    "change3": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "change3_title",
