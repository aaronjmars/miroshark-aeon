        "stack-shipped",
        "sep-2",
        "heading-stats",
        "grid-stats",
        "sep-3",
        "link-full"
      ]
    },
    "text-intro": {
      "type": "Text",
      "props": {
        "text": "Many surfaces became a surface network: 8 MiroShark PRs (#71-#78) converted last week's fan of independent endpoints into a self-reinforcing observability → distribution → discovery loop, closed Sunday night."
      }
    },
    "sep-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "heading-shipped": {
      "type": "Heading",
      "props": {
        "text": "Shipped",
        "level": "h2"
      }
    },
    "stack-shipped": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "item-1",
        "item-2",
        "item-3",
        "item-4"
      ]
    },
    "item-1": {
      "type": "Text",
      "props": {
        "text": "Three new surfaces (PR #72 tweet thread, PR #73 webhook delivery log, PR #74 surface usage analytics) closed the operator-observability loop"
      }
    },
    "item-2": {
      "type": "Text",
      "props": {
        "text": "Two metadata primitives (PR #75 reproduce.json citation key + PR #76 lineage navigator) made finished sims citable AND navigable"
      }
    },
    "item-3": {
      "type": "Text",
      "props": {
        "text": "PR #77 + #78 wired the metadata into surface-stats and turned the counter into ?sort=trending — first feedback loop where pulls decide what gets shown"
      }
    },
    "item-4": {
      "type": "Text",
      "props": {
        "text": "Aeon side: 4 self-corrections (project-lens rotation, token-report volume, heartbeat headers, MEMORY.md row caps)"
      }
    },
    "sep-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "heading-stats": {
      "type": "Heading",
      "props": {
        "text": "Stats",
        "level": "h2"
      }
    },
    "grid-stats": {
