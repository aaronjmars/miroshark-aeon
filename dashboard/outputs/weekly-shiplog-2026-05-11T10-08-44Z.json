      "props": {
        "text": "Weekly Shiplog — 2026-05-11",
        "level": "h1"
      }
    },
    "stack-content": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "text-intro",
