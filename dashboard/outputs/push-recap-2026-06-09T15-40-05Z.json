    "theme2_text": {
      "type": "Text",
      "props": {
        "text": "The 7-day re-derivation is retired. PR #55 encodes the May-31 noise-exclusion convention as explicit step 5 of the push-recap skill — aeonframework commits prefixed chore(scheduler): / chore(cron): / chore(<skill>): auto-commit are dropped on the agent repo before diff-reading. This recap is the first to run with the rule baked in; it filtered 30 cron commits, saved ~30 gh api calls. Second prompt-level self-improvement in 4 days."
      }
    },
