    "text-content": {
      "type": "Text",
      "props": {
        "text": "Yesterday MiroShark turned its hidden MCP server into a Settings panel for four AI editors. Today PR #45 ships the same trick for the REST surface — a 1.9K-line handwritten OpenAPI 3.1 spec, Swagger UI at /api/docs, and a regex-driven drift test that fails CI the moment routes and spec disagree. Two days, two machine-readable contracts over the same engine, each backed by a unit test that holds the implementation to the spec — at 829 stars / 152 forks with 5 days to go on the 1K-stars-by-Apr-30 target.",
        "variant": "body"
      },
      "children": []
    },
