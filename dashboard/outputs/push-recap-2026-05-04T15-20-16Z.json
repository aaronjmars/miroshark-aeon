        "variant": "body"
      }
    },
    "text-surfaces-detail": {
      "type": "Text",
      "props": {
        "text": "Inverse-direction 🔗 Share as link button beneath the Simulation Prompt + per-template-card 🔗 copy the URL from live form state.",
        "variant": "body"
      }
    },
    "text-forkref": {
      "type": "Text",
      "props": {
        "text": "The Fork-this-scenario buttons that PR #67 added to /share and /watch already covered the un-run-from-finished direction; PR #71 covers the un-run-from-tweet-or-blog direction.",
        "variant": "caption"
      }
    },
    "text-zerodeps": {
      "type": "Text",
      "props": {
        "text": "Pure frontend, zero new deps. DOMPurify already pinned for the markdown renderer.",
        "variant": "muted"
      }
