    "text-file1": {
      "type": "Text",
      "props": {
        "text": "frontend/src/utils/urlParams.js (+116) — NEW",
        "variant": "lead"
      }
    },
    "text-file1-desc": {
      "type": "Text",
      "props": {
        "text": "DOMPurify-backed sanitizer; HTML / javascript: URIs / control chars stripped, length-capped (scenario 500 / ask 300 / url 2000), template= restricted to [a-z0-9_-]+, ?url= rejected unless http(s):. One source of truth for read on / and write on / + per-template card.",
        "variant": "body"
      }
    },
    "text-file2": {
      "type": "Text",
      "props": {
        "text": "Home.vue (+385 / −2)",
        "variant": "lead"
      }
    },
    "text-file2-desc": {
      "type": "Text",
      "props": {
        "text": "onMounted reads + applies, fires one-shot fetchUrlDoc() for ?url=, hands ?template=<slug> to existing template-launch flow with redirect, strips params via router.replace so refresh / address-bar copy reflects edited state. Dismissible orange-edged banner + 🔗 Share as link button.",
        "variant": "body"
      }
    },
    "text-file3": {
      "type": "Text",
      "props": {
        "text": "TemplateGallery.vue (+68 / −10)",
        "variant": "lead"
      }
    },
    "text-file3-desc": {
      "type": "Text",
      "props": {
        "text": "Every preset card gets a 🔗 sibling next to Launch that copies ?template=<slug> with brief ✓ flash.",
        "variant": "body"
      }
    },
