    "impact_text": {
      "type": "Text",
      "props": {
        "text": "Eliminates a class of factual error in the highest-visibility surface the skill emits (push to Telegram/Discord/Slack). One extra gh call per article (~30s) prevents a user-visible mismatch. Pattern is reusable — if repo-article or thread-formatter ever exhibit the same drift, the same two-line addition applies."
      }
