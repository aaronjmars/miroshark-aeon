        "level": "h3"
      }
    },
    "changes_text": {
      "type": "Text",
      "props": {
        "text": "skills/project-lens/SKILL.md: new PR-status verification bullet under step 5's writing guidelines (run gh pr view, cache the verb); pre-notification assertion at the top of step 6 (notification verbs must match article body; re-query on doubt)."
      }
    },
