    "intro_text": {
      "type": "Text",
      "props": {
        "text": "2025 was the year slopsquatting got a name and a USENIX paper. MiroShark's 23-PR streak from #57 through #85 — every PR AI-authored — went the other way: zero new dependencies."
      }
    },
    "stats_stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "stat_1",
        "stat_2"
      ]
    },
    "stat_1": {
      "type": "Stat",
      "props": {
        "label": "LLM-recommended packages that don't exist (2025)",
        "value": "19.7%"
      }
    },
    "stat_2": {
      "type": "Stat",
      "props": {
        "label": "AI-authored PRs (#57-#85, zero new dependencies)",
        "value": "23"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {}
    },
    "details_text": {
      "type": "Text",
      "props": {
        "text": "Examples include yesterday's merged on-chain DKG publisher (using urllib.request instead of requests) and PR #85's stdlib SVG renderer opened this morning (using xml.etree.ElementTree instead of matplotlib)."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {}
    },
    "take_text": {
      "type": "Text",
      "props": {
        "text": "The contrarian take: bloat isn't a property of LLMs, it's a property of one-shot prompting. Agents that read a 23-PR git log inherit the discipline already in the repo.",
        "variant": "lead"
      }
    }
  }
