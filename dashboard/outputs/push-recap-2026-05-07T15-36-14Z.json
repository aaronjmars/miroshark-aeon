    "heading_pr73_hazards": {
      "type": "Heading",
      "props": {
        "text": "PR #73 caught its own concurrency hazards before merge",
        "level": "h2"
      }
    },
    "text_pr73_lock_cooldown": {
      "type": "Text",
      "props": {
        "text": "A second commit on the same PR added a module-level write lock around the read-modify-rename log window (so two concurrent dispatches can't drop each other's entries — exactly the visibility failure the log is meant to surface) plus a 5-second per-sim cooldown on the retry endpoint (so a leaked admin token can't be weaponized as an amplifier against the configured downstream).",
        "variant": "body"
      }
    },
    "text_pr73_test": {
      "type": "Text",
      "props": {
        "text": "Verified by a 32-thread barrier test.",
        "variant": "body"
      }
    },
