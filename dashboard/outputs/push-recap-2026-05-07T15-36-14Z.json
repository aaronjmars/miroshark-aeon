      "type": "Text",
      "props": {
        "text": "New backend module `surface_stats.py` (+215, frozen 11-key SURFACE_KEYS schema, atomic tempfile + os.replace, fire-and-forget) wired into every `_serve_X` handler in simulation.py, watch_landing (public sims only), and per-card feed dispatch",
        "variant": "body"
      }
    },
    "change_webhook_service": {
      "type": "Text",
      "props": {
        "text": "`webhook_service.py` (+365): new `webhook-log.jsonl` (50-line atomic cap, URL-masked before write), GET `/webhook-log` (admin-token), POST `/webhook-retry` (admin-token, rate-limited, bypasses per-process auto-fire dedup with `retry: true` payload marker)",
        "variant": "body"
      }
    },
    "change_embed_dialog": {
      "type": "Text",
      "props": {
        "text": "`EmbedDialog.vue` grew two new collapsible panels (+499 + 342): \"📡 Webhook delivery history\" (✓/✗/⏱ chips, Refresh + Retry) and \"📊 Distribution\" (sorted table with stable-sort tiebreaker, explicit cache caveat so operators don't compare counts to CDN dashboards and conclude the counter is broken)",
        "variant": "body"
      }
