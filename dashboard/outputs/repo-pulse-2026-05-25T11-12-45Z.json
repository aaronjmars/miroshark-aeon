{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse"
      },
      "children": [
        "date",
        "separator1",
        "repo-heading",
        "stats-stack",
        "separator2",
        "stargazers-section",
        "separator3",
        "forks-section"
      ]
    },
    "date": {
      "type": "Text",
      "props": {
        "text": "2026-05-25",
        "variant": "caption"
      }
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "repo-heading": {
      "type": "Heading",
      "props": {
        "text": "aaronjmars/MiroShark",
        "level": "h2"
      }
    },
    "stats-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stars-stat",
        "forks-stat"
      ]
    },
    "stars-stat": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1195",
        "delta": "+1",
        "trend": "up"
      }
    },
    "forks-stat": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "248",
        "delta": "+1",
        "trend": "up"
      }
    },
    "separator2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "stargazers-heading",
        "stargazer-link"
      ]
    },
    "stargazers-heading": {
      "type": "Heading",
      "props": {
        "text": "New stargazers",
        "level": "h3"
      }
    },
    "stargazer-link": {
      "type": "Link",
      "props": {
        "label": "irisBuild25",
        "href": "https://github.com/irisBuild25"
      }
    },
    "separator3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "forks-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "forks-heading",
        "fork-link"
      ]
    },
    "forks-heading": {
      "type": "Heading",
      "props": {
        "text": "New forks",
        "level": "h3"
      }
    },
    "fork-link": {
      "type": "StoryLink",
      "props": {
        "title": "gosunny2050/MiroShark",
        "href": "https://github.com/gosunny2050/MiroShark"
      }
    }
  }
}
