      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "ecosystem-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "ecosystem-heading",
        "ecosystem-para1",
        "pr145-link",
        "ecosystem-para2"
      ]
    },
    "ecosystem-heading": {
      "type": "Heading",
      "props": {
        "text": "Ecosystem-as-a-contract finished its arc",
        "level": "h3"
      }
    },
    "ecosystem-para1": {
      "type": "Text",
      "props": {
        "text": "The ECOSYSTEM.md registry got a logo column (and lost dormant Nookplot+Supercompact rows), got linked from README in en+zh, gained Capacitr and Sparkleware, and — most consequentially — gained a machine-readable JSON twin at GET /api/ecosystem.json. Aeon-built, +953/-19 across 10 files."
      }
    },
    "pr145-link": {
      "type": "StoryLink",
      "props": {
        "title": "PR #145",
        "href": "https://github.com/aaronjmars/miroshark-aeon/pull/145"
      }
    },
    "ecosystem-para2": {
      "type": "Text",
      "props": {
        "text": "surfaces.json and ecosystem.json now share one blueprint with identical ETag+cache posture — the platform exposes both meta-questions a new integrator hits ('what can I call?' / 'who else is built on this?') as twin JSON catalogs."
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "drift-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "drift-heading",
        "drift-para"
      ]
    },
    "drift-heading": {
      "type": "Heading",
      "props": {
        "text": "Drift guard saved itself within an hour",
        "level": "h3"
      }
    },
    "drift-para": {
      "type": "Text",
      "props": {
        "text": "PR #144 (sparkleware adding their own ECOSYSTEM.md row) merged 52 min after PR #145 — immediately breaking the catalog/Markdown sync the new tests guard. PR #146 closed the gap 5 minutes later. First live save of the design choice to hardcode rather than parse Markdown."
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "forget-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "forget-heading",
        "forget-para"
      ]
    },
    "forget-heading": {
      "type": "Heading",
      "props": {
        "text": "Aeon learned to forget on purpose",
        "level": "h3"
      }
    },
    "forget-para": {
      "type": "Text",
      "props": {
        "text": "PR #50 — repo-actions had suggested Operator Profile 13 times across May 8 → Jun 1. New memory/topics/blocked-features.md registry + a 30-sec upstream re-verify on each match means the idea is filtered out until SimulationState gains an operator field — at which point the entry self-deletes and the idea returns to the pool."
      }
    },
    "sep4": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "key-changes-section": {
