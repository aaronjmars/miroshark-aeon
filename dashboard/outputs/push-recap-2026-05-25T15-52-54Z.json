    "contributors-badge": {
      "type": "Badge",
      "props": {
        "text": "4th distinct external contributor",
        "variant": "secondary"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
