        "variant": "body"
      }
    },
    "platform-detail-1": {
      "type": "Text",
      "props": {
        "text": "/api/stats returns aggregate consensus/confidence/view counts (+ a Shields.io badge for READMEs)",
        "variant": "body"
      }
    },
    "platform-detail-2": {
      "type": "Text",
      "props": {
        "text": "/oembed makes share links auto-unfurl into rich cards on Notion/Ghost/Substack/WordPress",
        "variant": "body"
      }
    },
    "platform-detail-3": {
      "type": "Text",
      "props": {
        "text": "Both pure stdlib, zero new deps",
        "variant": "caption"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
