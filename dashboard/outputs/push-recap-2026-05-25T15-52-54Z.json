        "text": "Agent self-hardening",
        "level": "h2"
      }
    },
    "agent-text": {
      "type": "Text",
      "props": {
        "text": "aeon #45 adds an EXIT trap to prefetch-bankr.sh that stamps a 'crashed' status with the exit code, so tweet-allocator can tell a crashed prefetch from one that never ran (fixes the misleading May-24 alert).",
        "variant": "body"
      }
    },
    "sep4": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "key-changes-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "changes-heading",
        "change-1",
        "change-2",
        "change-3"
      ]
    },
    "changes-heading": {
      "type": "Heading",
      "props": {
        "text": "Key changes",
        "level": "h2"
      }
    },
    "change-1": {
      "type": "Text",
      "props": {
        "text": "New platform_stats.py (+444): one O(n) scan over all public+completed sims, 60s cache, ETag/304",
        "variant": "body"
      }
    },
    "change-2": {
      "type": "Text",
      "props": {
        "text": "New oembed_service.py (+207): host-allow-listed URL→sim_id parsing, never dereferences inbound url, JSON/XML payload",
        "variant": "body"
      }
    },
    "change-3": {
      "type": "Text",
      "props": {
        "text": "prefetch-bankr.sh EXIT trap (+25): writes {status:crashed, exit_code} when the script bails before its normal write_status",
        "variant": "body"
      }
    },
