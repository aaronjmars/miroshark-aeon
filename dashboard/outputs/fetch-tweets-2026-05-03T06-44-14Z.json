{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Fetch Tweets",
        "description": "2026-05-03"
      },
      "children": [
        "main"
      ]
    },
    "main": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "result",
        "queries"
      ]
    },
    "result": {
      "type": "Alert",
      "props": {
        "type": "info",
        "title": "No new tweets found"
      }
    },
    "queries": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "label",
        "items"
      ]
    },
    "label": {
      "type": "Text",
      "props": {
        "text": "Search queries:",
        "variant": "muted"
      }
    },
    "items": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "q1",
        "q2",
        "q3"
      ]
    },
    "q1": {
      "type": "Badge",
      "props": {
        "text": "$MIROSHARK"
      }
    },
    "q2": {
      "type": "Badge",
      "props": {
        "text": "@miroshark_"
      }
    },
    "q3": {
      "type": "Link",
      "props": {
        "label": "github.com/aaronjmars/miroshark",
        "href": "https://github.com/aaronjmars/miroshark"
      }
    }
  }
}
