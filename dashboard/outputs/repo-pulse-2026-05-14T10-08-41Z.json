{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Repo Pulse",
        "description": "aaronjmars/MiroShark"
      },
      "children": [
        "stack-main"
      ]
    },
    "stack-main": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "date-text",
        "stats-section",
        "sep1",
        "stargazers-section",
        "sep2",
        "forks-section"
      ]
    },
    "date-text": {
      "type": "Text",
      "props": {
        "text": "2026-05-14",
        "variant": "caption"
      }
    },
    "stats-section": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stat-stars",
        "stat-forks"
      ]
    },
    "stat-stars": {
      "type": "Stat",
      "props": {
        "label": "Stars",
        "value": "1145",
        "delta": "+2",
        "trend": "up"
      }
    },
    "stat-forks": {
      "type": "Stat",
      "props": {
        "label": "Forks",
        "value": "227",
        "delta": "+1",
        "trend": "up"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stargazers-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "stargazers-heading",
        "stargazers-list"
      ]
    },
    "stargazers-heading": {
      "type": "Heading",
      "props": {
        "text": "New stargazers",
        "level": "h4"
      }
    },
    "stargazers-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "link-techsd",
        "link-ngoluuduythai"
      ]
    },
    "link-techsd": {
      "type": "Link",
      "props": {
        "label": "github.com/techsd",
        "href": "https://github.com/techsd"
      }
    },
    "link-ngoluuduythai": {
      "type": "Link",
      "props": {
        "label": "github.com/ngoluuduythai",
        "href": "https://github.com/ngoluuduythai"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "forks-section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "forks-heading",
        "forks-list"
      ]
    },
    "forks-heading": {
      "type": "Heading",
      "props": {
        "text": "New forks",
        "level": "h4"
      }
    },
    "forks-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "link-fork-techsd"
      ]
    },
    "link-fork-techsd": {
      "type": "Link",
      "props": {
        "label": "github.com/techsd/MiroShark",
        "href": "https://github.com/techsd/MiroShark"
      }
    }
  }
}
