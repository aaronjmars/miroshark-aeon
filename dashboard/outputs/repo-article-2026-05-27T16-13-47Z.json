{
  "root": "card_main",
  "state": {},
  "elements": {
    "card_main": {
      "type": "Card",
      "props": {
        "title": "repo-article"
      },
      "children": [
        "article_heading",
        "context_para",
        "stats_grid",
        "separator1",
        "fixes_section",
        "separator2",
        "article_link"
      ]
    },
    "article_heading": {
      "type": "Heading",
      "props": {
        "text": "New Article: MiroShark Shipped a Week That Subtracted More Than It Added",
        "level": "h2"
      }
    },
    "context_para": {
      "type": "Text",
      "props": {
        "text": "After ~10 weeks of only adding consumable surfaces, MiroShark's merge log just went negative. An 8-pass cleanup (PR #116) deleted ~270 net lines and dead code while holding 971 tests green, and three crash fixes landed for bugs that only appear under real use — an Apple Silicon Metal-backend hang and two intermittent LLM-null report crashes. Adding a 23rd surface proves the engine is generative; deleting code and steering a reranker off the wrong GPU proves something harder — that it's being run.",
        "variant": "body"
      }
    },
    "stats_grid": {
      "type": "Grid",
      "props": {
        "columns": 2,
        "gap": "md"
      },
      "children": [
        "stat_cleanup",
        "stat_tests",
        "stat_fixes",
        "stat_surface"
      ]
    },
    "stat_cleanup": {
      "type": "Stat",
      "props": {
        "label": "Lines deleted (8-pass cleanup)",
        "value": "~270"
      }
    },
    "stat_tests": {
      "type": "Stat",
      "props": {
        "label": "Tests maintained green",
        "value": "971"
      }
    },
    "stat_fixes": {
      "type": "Stat",
      "props": {
        "label": "Crash fixes",
        "value": "3"
      }
    },
    "stat_surface": {
      "type": "Stat",
      "props": {
        "label": "New surfaces added",
        "value": "23"
      }
    },
    "separator1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "fixes_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "fixes_heading",
        "fixes_list"
      ]
    },
    "fixes_heading": {
      "type": "Heading",
      "props": {
        "text": "Bugs Fixed",
        "level": "h3"
      }
    },
    "fixes_list": {
